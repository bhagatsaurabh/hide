rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn(request) {
    	return request.auth != null;
    }
    function signedInUid(request, userId) {
    	return signedIn(request) && request.auth.uid == userId;
    }
    function signedInUsername(request) {
      return signedIn(request) && resource.data.uid == request.auth.uid;
    }

    match /users/{username} {
    	allow create: if false
      allow read: if signedInUsername(request)
      allow update: if false
      allow delete: if false
    }

    match /notifications/{userId}/messages/{notificationId} {
      allow create: if false
      allow read: if signedInUid(request, userId)
      allow update: if false
      allow delete: if false
    }
  }
}